# Hermes Agent - Environment Variables Example
# Copy this file to .env and fill in your values
# These are LOCAL reference values — the real .env used by Hermes is ~/.hermes/.env in WSL

# LLM Server
LLAMA_SERVER_URL=http://host.docker.internal:30000

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Web Search (https://brave.com/search/api/)
BRAVE_API_KEY=your_brave_api_key_here

# Google (Gemini, Places)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Image/Video generation (https://fal.ai/)
FAL_KEY=your_fal_key_here

# GitHub (https://github.com/settings/tokens)
GH_TOKEN=your_github_pat_here
GITHUB_TOKEN=your_github_pat_here
GH_REPO=your_username/your-pages-repo
GH_PAGES_TOKEN=your_github_pat_here
GH_PAGES_REPO=your_username/your-pages-repo

# Home Assistant (optional)
HA_URL=http://host.docker.internal:8123
HA_TOKEN=your_ha_long_lived_token_here

# ComfyUI Broker (optional — for image/video/music generation)
OPENCLAW_COMFYUI_LOCAL_BROKER_URL=http://host.docker.internal:8791
